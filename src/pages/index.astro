---
import { createAdminClient } from '../lib/supabase';

const ctaAdhesion = "https://www.helloasso.com/associations/le-saint-domingue/adhesions/adhesion";
const ctaDon = "https://www.helloasso.com/associations/graine-de-moutarde-fonds-de-dotation/collectes/rehabilitation-de-l-hotel-saint-domingue";
const ctaApport = "https://www.helloasso.com/associations/le-saint-domingue/boutiques/apports-associatifs";

const OBJECTIF = 300000;
const SUBVENTIONS = 25000;

const supabase = createAdminClient();
const { data: transactions } = await supabase
  .from('transactions')
  .select('type, montant');

const don = (transactions?.filter(t => t.type === 'adhesion' || t.type === 'don' || t.type === 'don_defiscalise').reduce((s, t) => s + t.montant, 0) ?? 0);
const apport = transactions?.filter(t => t.type === 'apport_associatif').reduce((s, t) => s + t.montant, 0) ?? 0;

const { count: participantsCount } = await supabase
  .from('membres')
  .select('id', { count: 'exact', head: true });

const stats = { don, apport, participants: participantsCount ?? 0 };
const total = stats.don + stats.apport;
const totalAvecSubventions = total + SUBVENTIONS;
const pct = Math.min(Math.round((totalAvecSubventions / OBJECTIF) * 100), 100);
const pctDon = Math.min(Math.round((stats.don / OBJECTIF) * 100), 100);
const pctApport = Math.min(Math.round((stats.apport / OBJECTIF) * 100), 100);
const pctSubventions = Math.min(Math.round((SUBVENTIONS / OBJECTIF) * 100), 100);

function euros(n: number) {
  return n.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO de base -->
  <title>Hôtel Saint Domingue — Foncière Citoyenne à Die</title>
  <meta name="description" content="Participez au rachat citoyen de l'Hôtel Saint Domingue à Die (Drôme). Une foncière citoyenne pour créer du logement accessible, de l'hébergement saisonnier et des espaces de vie partagés." />
