  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://saindo.org/" />

  <!-- Open Graph (Facebook, LinkedIn…) -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://saindo.org/" />
  <meta property="og:title" content="Hôtel Saint Domingue — Foncière Citoyenne à Die" />
  <meta property="og:description" content="Participez au rachat citoyen de l'Hôtel Saint Domingue à Die. Adhésion, don défiscalisé ou apport social : choisissez votre façon de soutenir ce projet d'intérêt général." />
  <meta property="og:image" content="https://saindo.org/schema-scic.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="Saint Domingue · Die" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Hôtel Saint Domingue — Foncière Citoyenne à Die" />
  <meta name="twitter:description" content="Participez au rachat citoyen de l'Hôtel Saint Domingue à Die. Adhésion, don défiscalisé ou apport social." />
  <meta name="twitter:image" content="https://saindo.org/schema-scic.jpg" />

  <!-- Données structurées JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Hôtel Saint Domingue — Foncière Citoyenne",
    "url": "https://saindo.org",
    "description": "Foncière citoyenne pour le rachat et la réhabilitation de l'Hôtel Saint Domingue à Die (Drôme), dans un objectif d'intérêt général.",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "44 rue Camille Buffardel",
      "addressLocality": "Die",
      "postalCode": "26150",
      "addressCountry": "FR"
    },
    "areaServed": "Die, Drôme, France"
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <span class="logo">Le Saindo</span>
      <div class="nav-actions">
        <a href="#contact" class="btn btn-nav">Contact</a>
        <a href="/login" class="btn btn-nav btn-nav-outline">Se connecter</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <img src="/hotel.jpg" alt="Devanture de l'Hôtel Saint Domingue à Die" class="hero-bg" />
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <h1>On rachète Le Saint Domingue avec une foncière citoyenne</h1>
      <p class="hero-sub">
        L'Hôtel Saint Domingue ferme ses portes. Ensemble, nous pouvons lui offrir une seconde vie — accessible, solidaire et ancrée dans le territoire.
      </p>

      <!-- JAUGE -->
      <div class="gauge">
        <div class="gauge-amounts">
          <div class="gauge-total">{euros(totalAvecSubventions)}</div>
          <div class="gauge-amounts-right">
            <div class="gauge-pct">{pct} %</div>
            <div class="gauge-goal">sur {euros(OBJECTIF)}</div>
          </div>
        </div>
        <div class="gauge-bar">
          <div class="gauge-fill gauge-fill--subvention" style={`width: ${pctSubventions}%`}></div>
          <div class="gauge-fill gauge-fill--apport" style={`width: ${pctApport}%`}></div>
          <div class="gauge-fill gauge-fill--don" style={`width: ${pctDon}%`}></div>
        </div>
        <div class="gauge-details">
          <span><strong style="color: #52B788">{euros(SUBVENTIONS)}</strong> subventions</span>
          <span><strong style="color: #74C69D">{euros(stats.apport)}</strong> apports associatifs</span>
          <span><strong style="color: #95D5B2">{euros(stats.don)}</strong> adhésions & dons</span>
        </div>
        <div class="gauge-participants">
          <strong>{stats.participants}</strong> participant{stats.participants > 1 ? 's' : ''}
        </div>
      </div>

      <div class="hero-cta-cards">
        <a href={ctaAdhesion} target="_blank" rel="noopener noreferrer" class="hero-cta-card">
          <span class="hero-cta-icon">🧑‍🤝‍🧑</span>
          <span class="hero-cta-label">Adhérer à l'association</span>
          <span class="hero-cta-arrow">→</span>
        </a>
        <a href={ctaDon} target="_blank" rel="noopener noreferrer" class="hero-cta-card">
          <span class="hero-cta-icon">💚</span>
          <span class="hero-cta-label">Faire un don défiscalisé</span>
          <span class="hero-cta-sub">via HelloAsso · Graines de moutarde</span>
          <span class="hero-cta-arrow">→</span>
        </a>
        <a href={ctaApport} target="_blank" rel="noopener noreferrer" class="hero-cta-card">
          <span class="hero-cta-icon">📈</span>
          <span class="hero-cta-label">Faire un apport associatif</span>
          <span class="hero-cta-sub">→ apport associatif SCIC</span>
          <span class="hero-cta-arrow">→</span>
        </a>
      </div>

      <a href="#pourquoi" class="hero-link">Découvrir le projet ↓</a>
    </div>
  </section>  

  <!-- POURQUOI -->
  <section id="pourquoi" class="section section-alt">
    <div class="container">
      <p class="section-label centered">le projet</p>
      <h2 style="text-align: left;">"On rachète un hôtel désaffecté en centre-ville pour bâtir un projet d'intérêt général"</h2>
      <div class="section-text">
        <p>
          L'hôtel Saint Domingue, situé en plein centre de Die, a cessé son activité en octobre 2024. Le bâtiment de 1 000 m² habitables n'est plus aux normes pour être exploité en l'état.
        </p>
        <p>
          Nous voulons œuvrer pour que ce bâtiment devienne la figure de proue d’un projet citoyen au coeur du Diois et sorte d’un marché spéculatif immobilier. Tous ensemble, imaginons une seconde vie pour cet établissement historique de Die.
        </p>
        <p class="highlight-text">Ensemble Concrétisons ce projet !</p>
      </div>
    </div>
  </section>

  <!-- COMMENT -->
  <section id="comment" class="section">
    <div class="container">
      <p class="section-label centered">Comment ?</p>
      <h2 style="text-align: left;">"On crée une foncière citoyenne pour acheter les murs et on imagine ensemble sa réhabilitation"</h2>
      <div class="section-text">
        <p>
        En créant une foncière citoyenne, société coopérative reposant sur une mobilisation de l'argent citoyen, nous allons acquérir le bâtiment et décider ensuite collectivement de son avenir.
        </p>
        <p>
          Vous pouvez nous permettre de limiter le recours à des organismes prêteurs en soutenant financièrement le projet.
        </p>
        <p>Ceci permettra de garantir l’ambition sociale et accessible qui constitue l’une des forces de ce projet. Nous pourrons alors offrir aux usagers de demain la possibilité d’expérimenter leurs idées et répondre ainsi au mieux aux besoins du territoire.</p>
      </div>
      <div class="schema-container">
        <img src="/schema-scic.jpg" alt="Schéma de la SCIC Saint Domingue" class="schema-img" />
      </div>
    </div>
  </section>


  <!-- DANS QUEL BUT -->
  <section id="but" class="section section-alt">
    <div class="container">
      <p class="section-label centered">Dans quel but ?</p>
      <h2 style="text-align: left;">"Proposer de l'hébergement accessible et adapté ; créer de nouveaux lieux de vie et de rencontres"</h2>
      <div class="section-text">
        <p>Sa réhabilitation pourra répondre à de nombreux besoins du territoire. Trois pistes ont été explorées avec les associations et les porteurs de projet locaux :</p>
        <p><strong>🏠 Logement accessible</strong> — Pour des seniors autonomes, des familles mono-parentales, des personnes exilées ou réfugiées, et des logements de répit.</p>
        <p><strong>🌿 Hébergement saisonnier</strong> — Petite auberge de jeunesse, pension de famille, accueil de saisonniers… Un lieu ouvert à tous et toutes.</p>
        <p><strong>🛍️ Activités en rez-de-chaussée</strong> — Des commerces participant à la revitalisation du centre-bourg, en lien avec les acteurs économiques existants.</p>
        <p><strong>🎭 Espace partagé</strong> — Un lieu de rencontre intergénérationnel pour des activités sociales et culturelles, ouvert à toute la communauté.</p>
        <p class="highlight-text">Les futurs usages seront imaginés et testés avec les acteurs du territoire, dans une logique d'intérêt général et en bonne intelligence avec ce qui existe déjà !</p>
      </div>
    </div>
  </section>

  <!-- COMMENT ON FINANCE -->
  <section id="financement" class="section">
    <div class="container">
      <p class="section-label centered">Comment on finance ?</p>
      <h2 style="text-align: left;">"Faire appel aux citoyens pour acquérir le bâtiment et financer les premiers travaux"</h2>
      <div class="section-text">
        <p>Pour financer l'acquisition du Saint-Domingue et les premiers travaux de mise en sécurité nous faisons appel aux citoyens. Vous pouvez nous aider en réalisant des dons défiscalisés à hauteur de 66%, en adhérant à l'association ou encore en versant des apports associatifs.</p>
        <p>Lorsque l'association sera transformée en Société Coopérative d'Intérêt Collectif (les démarches sont en cours…), ces apports associatifs seront transformés en parts sociales : 1 apport associatif sera alors égal à 1 part sociale.</p>
        <p>Une SCIC est une Société Coopérative d'Intérêt Collectif. C'est une société commerciale qui regroupe plusieurs parties prenantes autour d'un projet d'utilité sociale. Le principe de l'Économie Sociale et Solidaire dans lequel s'inscrivent les SCIC repose sur une égalité de traitement des sociétaires : quel que soit le nombre de parts sociales qu'il possède, 1 associé a 1 voix.</p>
        <p>En choisissant d'effectuer un ou plusieurs apports associatifs aujourd'hui, vous deviendrez automatiquement sociétaire de la coopérative.</p>
        <p>Ces parts sociales ne seront pas rémunérées et seront bloquées pendant une durée de 5 ans. C'est ce qui laissera au projet le temps de prendre de l'ampleur tout en garantissant sa pérennité.</p>
      </div>
    </div>
  </section>

  <!-- LES PHASES -->
  <section id="phases" class="section section-alt">
    <div class="container">
      <p class="section-label centered">Les phases</p>
      <h2 style="text-align: left;">"Les investissements"</h2>

      <div class="phases">

        <div class="phase">
          <div class="phase-header">
            <span class="phase-num">Phase 1</span>
            <div>
              <h3 class="phase-title">Achat du foncier et études préalables</h3>
              <span class="phase-budget">300 000 €</span>
            </div>
          </div>
          <p class="phase-tagline">"On rachète l'hôtel !"</p>
          <ul class="phase-items">
            <li><span>Achat du foncier</span><span>250 000 €</span></li>
            <li><span>Frais de notaire</span><span>18 800 €</span></li>
            <li><span>Géomètre</span><span>4 000 €</span></li>
            <li><span>Faisabilité architecturale (@Tout va bien)</span><span>12 000 €</span></li>
            <li><span>Accompagnement à la création d'une foncière citoyenne (@Villages vivants)</span><span>3 800 €</span></li>
            <li><span>Montage juridique de l'opération (@UR SCOOP)</span><span>2 400 €</span></li>
            <li><span>Coordination du projet sur 6 mois</span><span>9 000 €</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-header">
            <span class="phase-num">Phase 2</span>
            <div>
              <h3 class="phase-title">Mise en sécurité et premiers aménagements</h3>
              <span class="phase-budget">200 000 €</span>
            </div>
          </div>
          <p class="phase-tagline">"On monte le projet et on teste des usages !"</p>
          <ul class="phase-items">
            <li><span>Première phase de travaux : mise en sécurité, reprise des désordres structurels, reprise de l'étanchéité…</span><span>100 000 €</span></li>
            <li><span>Autorisation d'Occupation Temporaire pour expérimenter pendant 2 ans le fonctionnement, les usages et la mutualisation. Petits aménagements.</span><span>10 000 €</span></li>
            <li><span>Frais de fonctionnement pendant 2 ans (taxes, fluides, charges diverses)</span><span>30 000 €</span></li>
            <li><span>Coordination</span><span>15 000 €</span></li>
            <li><span>Maîtrise d'œuvre / conception</span><span>30 000 €</span></li>
            <li><span>Aléas (5%)</span><span>15 000 €</span></li>
          </ul>
        </div>

        <div class="phase">
          <div class="phase-header">
            <span class="phase-num">Phase 3</span>
            <div>
              <h3 class="phase-title">Travaux de réhabilitation globale</h3>
            </div>
          </div>
          <p class="phase-tagline">"Chaque euro supplémentaire finance l'opération globale de réhabilitation"</p>
          <ul class="phase-items">
            <li><span>Ces travaux seront dimensionnés au plus près des besoins finaux et financés en partie par les porteurs de projet</span><span></span></li>
            <li><span>Coordination</span><span>15 000 €</span></li>
            <li><span>Maîtrise d'œuvre / conception</span><span>120 000 €</span></li>
            <li><span>Travaux rez-de-chaussée — estimation</span><span>300 000 €</span></li>
            <li><span>Travaux étages — estimation</span><span>1 400 000 €</span></li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section id="rejoindre" class="section section-cta">
    <div class="container">
      <p class="section-label centered" style="color: var(--green-light);">Rejoignez l'aventure !</p>
      <h2 class="centered" style="color: white;">Choisissez votre façon de soutenir le projet</h2>
      <p class="section-intro centered" style="color: rgba(255,255,255,0.8);">Trois manières concrètes de contribuer à ce projet d'intérêt général.</p>

      <div class="cta-cards">
        <div class="cta-card" id="adhesion">
          <div class="cta-card-icon">🧑‍🤝‍🧑</div>
          <h3>Adhérer à l'association</h3>
          <p>Rejoignez la communauté de citoyens engagés qui portent ce projet. Votre adhésion vous donne voix au chapitre.</p>
          <a href={ctaAdhesion} target="_blank" rel="noopener noreferrer" class="btn btn-white">Adhérer maintenant</a>
        </div>

        <div class="cta-card" id="don">
          <div class="cta-card-icon">💚</div>
          <h3>Faire un don défiscalisé</h3>
          <p>Via HelloAsso et le fonds de dotation <em>Graines de moutarde</em>. Votre don est défiscalisable et soutient directement l'acquisition du bâtiment.</p>
          <a href={ctaDon} target="_blank" rel="noopener noreferrer" class="btn btn-white">Faire un don</a>
        </div>

        <div class="cta-card" id="apport">
          <div class="cta-card-icon">📈</div>
          <h3>Faire un apport associatif</h3>
          <p>Votre apport deviendra des parts sociales de la SCIC. Vous devenez co-propriétaire et participez à la gouvernance du projet.</p>
          <a href={ctaApport} target="_blank" rel="noopener noreferrer" class="btn btn-white">Devenir sociétaire</a>
        </div>
      </div>

      <p class="partage-text">
        Vous pouvez aussi <strong>diffuser, partager et en parler autour de vous</strong> — c'est déjà une contribution précieuse !
      </p>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section section-contact">
    <div class="container">
      <p class="section-label centered">Nous contacter</p>
      <h2 class="centered">Une question ? Écrivez-nous.</h2>
      <div class="contact-cards">
        <a href="mailto:contact@saindo.org" class="contact-card">
          <div class="contact-icon">✉️</div>
          <div class="contact-info">
            <span class="contact-label">Email</span>
            <span class="contact-value">contact@saindo.org</span>
          </div>
        </a>
        <a href="tel:+33615733705" class="contact-card">
          <div class="contact-icon">📞</div>
          <div class="contact-info">
            <span class="contact-label">Erwan</span>
            <span class="contact-value">06 15 73 37 05</span>
          </div>
        </a>
        <div class="contact-card">
          <div class="contact-icon">📍</div>
          <div class="contact-info">
            <span class="contact-label">Adresse</span>
            <span class="contact-value">44 rue Camille Buffardel<br />26150 Die</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-inner">
      <div>
        <strong>Hôtel Saint Domingue</strong>
        <span>44 rue Camille Buffardel, Die (26)</span>
      </div>
      <div>
        <a href="https://saindo.org">saindo.org</a>
      </div>
    </div>
  </footer>

</body>
</html>

<style>
  :root {
    --green: #2D6A4F;
    --green-dark: #1B4332;
    --green-light: #95D5B2;
    --amber: #E76F51;
    --amber-dark: #C75B3A;
    --bg: #F7F3EE;
    --bg-alt: #EDE8E1;
    --text: #1C1C1E;
    --text-muted: #5C5C6B;
    --white: #FFFFFF;
    --radius: 12px;
    --shadow: 0 4px 24px rgba(0,0,0,0.08);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.65;
  }

  /* NAV */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(247,243,238,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: var(--green-dark);
    font-weight: 700;
  }

  /* BUTTONS */
  .btn {
    display: inline-block;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.2s;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--amber);
    color: var(--white);
  }
  .btn-primary:hover { background: var(--amber-dark); transform: translateY(-1px); }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .btn-nav {
    background: var(--green);
    color: var(--white);
    padding: 10px 20px;
    font-size: 0.875rem;
    white-space: nowrap;
  }
  .btn-nav:hover { background: var(--green-dark); }
  .btn-nav-outline {
    background: transparent;
    color: var(--green-dark);
    border: 1.5px solid var(--green);
  }
  .btn-nav-outline:hover { background: var(--green); color: var(--white); }
  .btn-white {
    background: var(--white);
    color: var(--green-dark);
    border: 2px solid var(--white);
  }
  .btn-white:hover { background: transparent; color: var(--white); }

  /* HERO */
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    padding: 80px 24px;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(27,67,50,0.88) 0%, rgba(45,106,79,0.75) 60%, rgba(82,183,136,0.55) 100%);
    z-index: 1;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
  }
  .hero-eyebrow {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-light);
    margin-bottom: 20px;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    color: var(--white);
