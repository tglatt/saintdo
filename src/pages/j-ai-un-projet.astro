---
import Nav from '../components/Nav.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>J'ai un projet — Le Saindo</title>
  <meta name="description" content="Vous avez un projet pour l'Hôtel Saint Domingue ? Cette page est en cours de construction." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <Nav />

  <main>
    <div class="container">
      <p class="section-label">J'ai un projet</p>
      <h1>Cette page est en construction</h1>
      <p class="intro">Nous préparons cette page pour vous permettre de proposer votre projet pour l'Hôtel Saint Domingue. Revenez bientôt !</p>
      <a href="/" class="btn">Retour à l'accueil</a>
    </div>
  </main>

  <ContactSection />
  <Footer />

</body>
</html>

<style>
  :root {
    --green: #6663A0;
    --green-dark: #2D2A68;
    --green-light: #B0ADD4;
    --bg: #F7F6FB;
    --bg-alt: #EEEDF6;
    --text: #1C1C1E;
    --text-muted: #5C5C6B;
    --amber: #A07C10;
    --radius: 12px;
    --shadow: 0 4px 24px rgba(0,0,0,0.08);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.65;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main { flex: 1; display: flex; align-items: center; padding: 96px 24px; }
  .container { max-width: 560px; margin: 0 auto; text-align: center; }

  .section-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 12px;
  }
  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    color: var(--green-dark);
    line-height: 1.25;
    margin-bottom: 16px;
  }
  .intro {
    font-size: 1.02rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 32px;
  }

  .btn {
    display: inline-block;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    background: var(--green);
    color: white;
    transition: background 0.2s;
  }
  .btn:hover { background: var(--green-dark); }
</style>
