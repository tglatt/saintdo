---
import { createAdminClient } from '../../lib/supabase';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const supabase = createAdminClient();

const { data: membres } = await supabase
  .from('membres')
  .select('id, email, nom, prenom, structure, role, created_at')
  .order('nom', { ascending: true });

const { data: transactions } = await supabase
  .from('transactions')
  .select('membre_id, type, montant, date');

const { data: lastSync } = await supabase
  .from('syncs')
  .select('ended_at, status, nb_membres, nb_transactions, message')
  .order('started_at', { ascending: false })
  .limit(1)
  .single();

// Calculs globaux
const totalMembres = membres?.length ?? 0;
const totalAdhesion = transactions?.filter(t => t.type === 'adhesion')
  .reduce((s, t) => s + t.montant, 0) ?? 0;
const totalDon = transactions?.filter(t => t.type === 'don')
  .reduce((s, t) => s + t.montant, 0) ?? 0;
const totalApport = transactions?.filter(t => t.type === 'apport_associatif')
  .reduce((s, t) => s + t.montant, 0) ?? 0;

// Index transactions par membre
const txByMembre = new Map<string, typeof transactions>();
for (const tx of transactions ?? []) {
  if (!txByMembre.has(tx.membre_id)) txByMembre.set(tx.membre_id, []);
  txByMembre.get(tx.membre_id)!.push(tx);
}

function euros(n: number) {
  return n.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
}
function fmtDate(iso: string | null) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
}
function fmtDateTime(iso: string | null) {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('fr-FR', {
    day: '2-digit', month: '2-digit', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
    timeZone: 'Europe/Paris',
  });
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Saint Domingue</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <nav>
    <div class="nav-inner">
      <a href="/" class="logo">Saint Domingue</a>
      <div class="nav-right">
        <a href="/espace-membre" class="btn-member">Mon espace</a>
        <span class="user-email">{user.email}</span>
        <a href="/auth/logout" class="btn-logout">Déconnexion</a>
      </div>
    </div>
  </nav>

  <main>
    <div class="container">

      <header class="page-header">
        <h1>Administration</h1>
        <p class="sub">Vue d'ensemble des membres et des transactions.</p>
      </header>

      <!-- STATS GLOBALES -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Adhésions</div>
          <div class="stat-value">{euros(totalAdhesion)}</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Dons</div>
          <div class="stat-value">{euros(totalDon)}</div>
        </div>
        <div class="stat-card stat-card--accent">
          <div class="stat-label">Apports associatifs</div>
          <div class="stat-value">{euros(totalApport)}</div>
        </div>
        <div class="stat-card stat-card--total">
          <div class="stat-label">Total collecté</div>
          <div class="stat-value">{euros(totalAdhesion + totalDon + totalApport)}</div>
        </div>
      </div>

      <!-- SYNC STATUS -->
      <div class={`sync-status sync-status--${lastSync?.status ?? 'none'}`}>
        <span class="sync-dot"></span>
        <span>
          {lastSync ? (
            <>
              Dernière sync : <strong>{fmtDateTime(lastSync.ended_at)}</strong>
              {lastSync.status === 'success'
                ? ` — ${lastSync.nb_membres} membres, ${lastSync.nb_transactions} transactions`
                : ` — Erreur : ${lastSync.message}`}
            </>
          ) : 'Aucune synchronisation effectuée'}
        </span>
      </div>

      <!-- LISTE MEMBRES -->
      <section class="section">
        <div class="section-header">
          <h2>Membres ({totalMembres})</h2>
          <input
            type="text"
            id="search"
            placeholder="Rechercher par nom ou email…"
            autocomplete="off"
          />
        </div>
        <div class="table-wrapper">
          <table id="membres-table">
            <thead>
              <tr>
                <th data-col="0" class="sortable">Nom <span class="sort-icon">↕</span></th>
                <th data-col="1" class="sortable">Email <span class="sort-icon">↕</span></th>
                <th data-col="2" class="sortable">Date d'adhésion <span class="sort-icon">↕</span></th>
                <th data-col="3" class="sortable right">Adhésions <span class="sort-icon">↕</span></th>
                <th data-col="4" class="sortable right">Dons <span class="sort-icon">↕</span></th>
                <th data-col="5" class="sortable right">Apports <span class="sort-icon">↕</span></th>
                <th data-col="6">Rôle</th>
              </tr>
            </thead>
            <tbody>
              {membres?.map(m => {
                const txs = txByMembre.get(m.id) ?? [];
                const adhTxs = txs.filter(t => t.type === 'adhesion');
                const adh = adhTxs.reduce((s, t) => s + t.montant, 0);
                const don = txs.filter(t => t.type === 'don').reduce((s, t) => s + t.montant, 0);
                const app = txs.filter(t => t.type === 'apport_associatif').reduce((s, t) => s + t.montant, 0);
                const dateAdhesion = adhTxs.map(t => t.date).filter(Boolean).sort()[0] ?? null;
                return (
                  <tr>
                    <td class="bold">{[m.nom, m.prenom].filter(Boolean).join(' ') || '—'}</td>
                    <td class="muted">{m.email}</td>
                    <td class="muted">{fmtDate(dateAdhesion)}</td>
                    <td class="right">{adh > 0 ? euros(adh) : '—'}</td>
                    <td class="right">{don > 0 ? euros(don) : '—'}</td>
                    <td class="right">{app > 0 ? euros(app) : '—'}</td>
                    <td>
                      <span class={`badge badge-${m.role}`}>
                        {m.role === 'admin' ? 'Admin' : 'Membre'}
                      </span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>

    </div>
  </main>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: #F7F3EE;
    color: #1C1C1E;
    min-height: 100vh;
  }

  nav {
    background: white;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1B4332;
    text-decoration: none;
  }
  .nav-right { display: flex; align-items: center; gap: 16px; }
  .user-email { font-size: 0.85rem; color: #5C5C6B; }
  .btn-logout, .btn-member {
    font-size: 0.85rem;
    color: #5C5C6B;
    text-decoration: none;
    padding: 6px 12px;
    border: 1px solid #E5E5EA;
    border-radius: 6px;
    transition: all 0.2s;
  }
  .btn-logout:hover, .btn-member:hover { background: #F7F3EE; color: #1C1C1E; }

  main { padding: 48px 24px; }
  .container { max-width: 1200px; margin: 0 auto; }

  .page-header { margin-bottom: 40px; }
  h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: #1B4332;
    margin-bottom: 8px;
  }
  .sub { color: #5C5C6B; }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  .stat-card {
    background: white;
    border-radius: 12px;
    padding: 24px 20px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
  }
  .stat-card--accent { border-top: 3px solid #2D6A4F; }
  .stat-card--total { border-top: 3px solid #E76F51; }
  .stat-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #5C5C6B; margin-bottom: 8px; }
  .stat-value { font-family: 'Playfair Display', serif; font-size: 1.6rem; color: #1B4332; }

  .sync-status {
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: #5C5C6B;
  }
  .sync-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .sync-status--success .sync-dot { background: #22C55E; }
  .sync-status--error .sync-dot { background: #EF4444; }
  .sync-status--none .sync-dot { background: #D1D5DB; }
  .sync-status strong { color: #1C1C1E; }

  .section h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: #1B4332;
    margin-bottom: 16px;
  }

  .table-wrapper { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    min-width: 700px;
  }
  th {
    text-align: left;
    padding: 12px 16px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #5C5C6B;
    background: #F7F3EE;
    border-bottom: 1px solid #E5E5EA;
  }
  td {
    padding: 12px 16px;
    font-size: 0.88rem;
    border-bottom: 1px solid #F0EDE8;
  }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #FAFAF8; }
  .right { text-align: right; }
  .bold { font-weight: 600; }
  .muted { color: #5C5C6B; }

  .badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .badge-membre { background: #F0FDF4; color: #166534; }
  .badge-admin { background: #FEF3C7; color: #92400E; }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .section-header h2 { margin-bottom: 0; }

  #search {
    padding: 8px 14px;
    border: 1.5px solid #E5E5EA;
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    width: 260px;
    transition: border-color 0.2s;
  }
  #search:focus { border-color: #2D6A4F; }

  tr.hidden { display: none; }

  th.sortable { cursor: pointer; user-select: none; }
  th.sortable:hover { background: #EDE8E1; }
  th.sort-asc .sort-icon::after { content: ' ↑'; }
  th.sort-desc .sort-icon::after { content: ' ↓'; }
  .sort-icon { font-size: 0.7rem; color: #9CA3AF; }
  th.sort-asc .sort-icon, th.sort-desc .sort-icon { color: #2D6A4F; }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .user-email { display: none; }
    #search { width: 100%; }
  }
</style>

<script>
  // ── Filtrage ──────────────────────────────────────────────────────────────
  const search = document.getElementById('search') as HTMLInputElement;
  const tbody = document.querySelector<HTMLTableSectionElement>('#membres-table tbody')!;

  function getRows() {
    return Array.from(tbody.querySelectorAll<HTMLTableRowElement>('tr'));
  }

  search.addEventListener('input', () => {
    const q = search.value.toLowerCase().trim();
    getRows().forEach(row => {
      const nom = row.cells[0]?.textContent?.toLowerCase() ?? '';
      const email = row.cells[1]?.textContent?.toLowerCase() ?? '';
      row.classList.toggle('hidden', q !== '' && !nom.includes(q) && !email.includes(q));
    });
  });

  // ── Tri ───────────────────────────────────────────────────────────────────
  let sortCol = -1;
  let sortAsc = true;

  document.querySelectorAll<HTMLTableCellElement>('th.sortable').forEach(th => {
    th.addEventListener('click', () => {
      const col = parseInt(th.dataset.col ?? '0');
      if (sortCol === col) {
        sortAsc = !sortAsc;
      } else {
        sortCol = col;
        sortAsc = true;
      }

      // Mettre à jour les classes des en-têtes
      document.querySelectorAll('th').forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
      th.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');

      // Trier les lignes
      const rows = getRows();
      rows.sort((a, b) => {
        const aText = a.cells[col]?.textContent?.trim() ?? '';
        const bText = b.cells[col]?.textContent?.trim() ?? '';

        // Détecter si c'est un montant (contient €)
        const aNum = parseFloat(aText.replace(/[^0-9,.-]/g, '').replace(',', '.'));
        const bNum = parseFloat(bText.replace(/[^0-9,.-]/g, '').replace(',', '.'));
        const isNum = !isNaN(aNum) && !isNaN(bNum);

        // Détecter si c'est une date (format JJ/MM/AAAA)
        const dateRe = /^\d{2}\/\d{2}\/\d{4}$/;
        const isDate = dateRe.test(aText) && dateRe.test(bText);

        let cmp = 0;
        if (isDate) {
          const [ad, am, ay] = aText.split('/');
          const [bd, bm, by] = bText.split('/');
          cmp = new Date(`${ay}-${am}-${ad}`).getTime() - new Date(`${by}-${bm}-${bd}`).getTime();
        } else if (isNum) {
          cmp = aNum - bNum;
        } else {
          cmp = aText.localeCompare(bText, 'fr');
        }

        return sortAsc ? cmp : -cmp;
      });

      rows.forEach(row => tbody.appendChild(row));
    });
  });
</script>
