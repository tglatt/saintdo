---
import { createAdminClient } from '../../lib/supabase';
import '../../styles/theme.css';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const supabase = createAdminClient();

const { data: membres } = await supabase
  .from('membres')
  .select('id, email, nom, prenom, structure, role, convention_enabled, created_at, convention_email_sent_at')
  .order('nom', { ascending: true });

const { data: transactions } = await supabase
  .from('transactions')
  .select('membre_id, type, montant, date');

const { data: lastSync } = await supabase
  .from('syncs')
  .select('ended_at, status, nb_membres, nb_transactions, message')
  .order('started_at', { ascending: false })
  .limit(1)
  .single();

const { data: signedConventions } = await supabase
  .from('conventions')
  .select('membre_id');
const signedMemberIds = new Set(signedConventions?.map(c => c.membre_id) ?? []);

const conventionEnabledIds = new Set(
  membres?.filter(m => m.convention_enabled).map(m => m.id) ?? []
);
const apportMemberIds = new Set(
  transactions?.filter(t => t.type === 'apport_associatif').map(t => t.membre_id) ?? []
);
const recentEmailIds = new Set(
  membres?.filter(m => {
    if (!m.convention_email_sent_at) return false;
    return Date.now() - new Date(m.convention_email_sent_at).getTime() < 24 * 60 * 60 * 1000;
  }).map(m => m.id) ?? []
);
const pendingConventionCount = [...apportMemberIds].filter(
  id => conventionEnabledIds.has(id) && !signedMemberIds.has(id) && !recentEmailIds.has(id)
).length;

const totalMembres = membres?.length ?? 0;

const txByMembre = new Map<string, typeof transactions>();
for (const tx of transactions ?? []) {
  if (!txByMembre.has(tx.membre_id)) txByMembre.set(tx.membre_id, []);
  txByMembre.get(tx.membre_id)!.push(tx);
}

function euros(n: number) {
  return n.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
}
function fmtDate(iso: string | null) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
}
function fmtDateTime(iso: string | null) {
  if (!iso) return '—';
  return new Date(iso).toLocaleString('fr-FR', {
    day: '2-digit', month: '2-digit', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
    timeZone: 'Europe/Paris',
  });
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Saint Domingue</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <nav>
    <div class="nav-inner">
      <a href="/" class="logo">Saint Domingue</a>
      <div class="nav-right">
        <a href="/espace-membre" class="btn-member">Mon espace</a>
        <span class="user-email">{user.email}</span>
        <a href="/auth/logout" class="btn-logout">Déconnexion</a>
      </div>
    </div>
  </nav>

  <subnav>
    <div class="subnav-inner">
      <a href="/admin" class="subnav-link active">Membres</a>
      <a href="/admin/transactions" class="subnav-link">Transactions</a>
      <a href="/admin/statistiques" class="subnav-link">Statistiques</a>
    </div>
  </subnav>

  <main>
    <div class="container">

      <header class="page-header">
        <h1>Administration</h1>
        <p class="sub">Vue d'ensemble des membres et des transactions.</p>
      </header>

      <!-- SYNC STATUS -->
      <div class={`sync-status sync-status--${lastSync?.status ?? 'none'}`}>
        <span class="sync-dot"></span>
        <span>
          {lastSync ? (
            <>
              Dernière sync : <strong>{fmtDateTime(lastSync.ended_at)}</strong>
              {lastSync.status === 'success'
                ? ` — ${lastSync.nb_membres} membres, ${lastSync.nb_transactions} transactions`
                : ` — Erreur : ${lastSync.message}`}
            </>
          ) : 'Aucune synchronisation effectuée'}
        </span>
      </div>

      <!-- LISTE MEMBRES -->
      <section class="section">
        <div class="section-header">
          <h2>Membres ({totalMembres})</h2>
          <div class="section-header-right">
            <input type="text" id="search" placeholder="Rechercher par nom ou email…" autocomplete="off" />
            {pendingConventionCount > 0 && (
              <button id="btn-send-conventions" class="btn-create btn-create--secondary">Envoyer les conventions ({pendingConventionCount})</button>
            )}
            <button id="btn-create-membre" class="btn-create">+ Nouveau membre</button>
          </div>
        </div>
        <div class="table-wrapper">
          <table id="membres-table">
            <thead>
              <tr>
                <th data-col="0" class="sortable">Nom <span class="sort-icon">↕</span></th>
                <th data-col="1" class="sortable">Email <span class="sort-icon">↕</span></th>
                <th data-col="2" class="sortable">Date d'adhésion <span class="sort-icon">↕</span></th>
                <th data-col="3" class="sortable right">Adhésions <span class="sort-icon">↕</span></th>
                <th data-col="4" class="sortable right">Dons <span class="sort-icon">↕</span></th>
                <th data-col="5" class="sortable right">Dons défiscalisés <span class="sort-icon">↕</span></th>
                <th data-col="6" class="sortable right">Apports <span class="sort-icon">↕</span></th>
                <th data-col="7">Rôle</th>
              </tr>
            </thead>
            <tbody>
              {membres?.map(m => {
                const txs = txByMembre.get(m.id) ?? [];
                const adhTxs = txs.filter(t => t.type === 'adhesion');
                const adh = adhTxs.reduce((s, t) => s + t.montant, 0);
                const don = txs.filter(t => t.type === 'don').reduce((s, t) => s + t.montant, 0);
                const donDef = txs.filter(t => t.type === 'don_defiscalise').reduce((s, t) => s + t.montant, 0);
                const app = txs.filter(t => t.type === 'apport_associatif').reduce((s, t) => s + t.montant, 0);
                const dateAdhesion = adhTxs.map(t => t.date).filter(Boolean).sort()[0] ?? null;
                return (
                  <tr class="clickable" data-id={m.id}>
                    <td class="bold">
                      {signedMemberIds.has(m.id) && <span class="convention-signed" title="Convention signée">✓</span>}
                      {[m.nom, m.prenom].filter(Boolean).join(' ') || '—'}
                    </td>
                    <td class="muted">{m.email}</td>
                    <td class="muted">{fmtDate(dateAdhesion)}</td>
                    <td class="right">{adh > 0 ? euros(adh) : '—'}</td>
                    <td class="right">{don > 0 ? euros(don) : '—'}</td>
                    <td class="right">{donDef > 0 ? euros(donDef) : '—'}</td>
                    <td class="right">{app > 0 ? euros(app) : '—'}</td>
                    <td>
                      <span class={`badge badge-${m.role}`}>
                        {m.role === 'admin' ? 'Admin' : 'Membre'}
                      </span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>

    </div>
  </main>

  <!-- MODAL ENVOI CONVENTIONS EN MASSE -->
  <div id="bulk-convention-overlay" class="modal-overlay hidden">
    <div class="modal tx-modal">
      <div class="modal-header">
        <div>
          <h2>Envoyer les conventions</h2>
        </div>
        <button id="bulk-convention-close" class="modal-close">✕</button>
      </div>
      <div class="modal-body">
        <p class="bulk-description">
          <strong>{pendingConventionCount} membre{pendingConventionCount > 1 ? 's' : ''}</strong>
          {pendingConventionCount > 1 ? ' recevront' : ' recevra'} un email avec son lien de signature de convention d'apport.
        </p>
        <p id="bulk-error" class="tx-error hidden"></p>
        <div class="form-actions">
          <button type="button" id="bulk-convention-cancel">Annuler</button>
          <button type="button" id="bulk-convention-submit">Envoyer</button>
        </div>
      </div>
    </div>
  </div>

  <!-- MODAL NOUVEAU MEMBRE -->
  <div id="membre-overlay" class="modal-overlay hidden">
    <div class="modal tx-modal">
      <div class="modal-header">
        <div>
          <h2>Nouveau membre</h2>
        </div>
        <button id="membre-close" class="modal-close">✕</button>
      </div>
      <div class="modal-body">
        <form id="membre-form">
          <div class="form-row">
            <div class="form-group">
              <label for="m-nom">Nom</label>
              <input type="text" id="m-nom" placeholder="Dupont" />
            </div>
            <div class="form-group">
              <label for="m-prenom">Prénom</label>
              <input type="text" id="m-prenom" placeholder="Jean" />
            </div>
          </div>
          <div class="form-group">
            <label for="m-email">Email <span class="required">*</span></label>
            <input type="email" id="m-email" required placeholder="jean.dupont@example.com" />
          </div>
          <div class="form-group">
            <label for="m-structure">Structure</label>
            <input type="text" id="m-structure" placeholder="Association, entreprise…" />
          </div>
          <div class="form-group">
            <label for="m-role">Rôle</label>
            <select id="m-role">
              <option value="membre">Membre</option>
              <option value="admin">Admin</option>
            </select>
          </div>
          <p id="membre-error" class="tx-error hidden"></p>
          <div class="form-actions">
            <button type="button" id="membre-cancel">Annuler</button>
            <button type="submit" id="membre-submit">Créer</button>
          </div>
        </form>
      </div>
    </div>
  </div>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
    min-height: 100vh;
  }

  nav {
    background: white;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
  }
  .nav-right { display: flex; align-items: center; gap: 12px; }

  subnav {
    background: white;
    border-bottom: 1px solid var(--color-border);
  }
  .subnav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    gap: 4px;
  }
  .subnav-link {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    padding: 10px 14px;
    border-bottom: 2px solid transparent;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .subnav-link:hover { color: var(--color-primary); }
  .subnav-link.active { color: var(--color-primary); border-bottom-color: var(--color-primary-mid); font-weight: 600; }
  .user-email { font-size: 0.85rem; color: var(--color-muted); }
  .btn-logout, .btn-member {
    font-size: 0.85rem;
    color: var(--color-muted);
    text-decoration: none;
    padding: 6px 12px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    transition: all 0.2s;
  }
  .btn-logout:hover, .btn-member:hover { background: var(--color-bg); color: var(--color-text); }

  main { padding: 48px 24px; }
  .container { max-width: 1200px; margin: 0 auto; }

  .page-header { margin-bottom: 40px; }
  h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: var(--color-primary);
    margin-bottom: 8px;
  }
  .sub { color: var(--color-muted); }

  .sync-status {
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .sync-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .sync-status--success .sync-dot { background: var(--color-success); }
  .sync-status--error .sync-dot { background: var(--color-error); }
  .sync-status--none .sync-dot { background: var(--color-subtle); }
  .sync-status strong { color: var(--color-text); }

  .section h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  .table-wrapper { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    min-width: 700px;
  }
  th {
    text-align: left;
    padding: 12px 16px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  td {
    padding: 12px 16px;
    font-size: 0.88rem;
    border-bottom: 1px solid var(--color-border-light);
  }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--color-surface); }
  .right { text-align: right; }
  .bold { font-weight: 600; }
  .muted { color: var(--color-muted); }

  .badge { display: inline-block; padding: 2px 10px; border-radius: 99px; font-size: 0.75rem; font-weight: 600; }
  .badge-membre { background: var(--badge-membre-bg); color: var(--badge-membre-text); }
  .badge-admin  { background: var(--badge-admin-bg);  color: var(--badge-admin-text); }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .section-header h2 { margin-bottom: 0; }
  .section-header-right { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .btn-create {
    padding: 8px 16px;
    background: var(--color-primary-mid);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .btn-create:hover { background: var(--color-primary); }
  .btn-create--secondary {
    background: white;
    color: var(--color-primary-mid);
    border: 1.5px solid var(--color-primary-mid);
  }
  .btn-create--secondary:hover { background: var(--color-success-bg); }
  .bulk-description { font-size: 0.9rem; color: var(--color-text); margin-bottom: 24px; line-height: 1.6; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .required { color: var(--color-error); }

  #search {
    padding: 8px 14px;
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    width: 260px;
    transition: border-color 0.2s;
  }
  #search:focus { border-color: var(--color-primary-mid); }

  tr.hidden { display: none; }
  tr.clickable { cursor: pointer; }
  tr.clickable:hover td { background: var(--color-success-bg); }

  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .modal-overlay.hidden { display: none; }

  .modal {
    background: white;
    border-radius: 16px;
    width: 100%;
    max-width: 480px;
    max-height: 80vh;
    overflow-y: auto;
    box-shadow: 0 8px 48px rgba(0,0,0,0.18);
  }
  .modal-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: 28px 28px 20px;
    border-bottom: 1px solid var(--color-border-light);
    position: sticky;
    top: 0;
    background: white;
    z-index: 1;
  }
  .modal-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: var(--color-primary);
    margin: 0 0 4px;
  }
  .modal-close {
    background: none;
    border: none;
    font-size: 1.1rem;
    color: var(--color-subtle);
    cursor: pointer;
    padding: 4px 8px;
    flex-shrink: 0;
  }
  .modal-close:hover { color: var(--color-text); }
  .modal-body { padding: 24px 28px; }

  .tx-modal { max-width: 440px; }
  .form-group { margin-bottom: 20px; }
  .form-group label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    margin-bottom: 6px;
  }
  .form-group input,
  .form-group select {
    width: 100%;
    padding: 10px 14px;
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    background: white;
    color: var(--color-text);
  }
  .form-group input:focus,
  .form-group select:focus { border-color: var(--color-primary-mid); }
  .form-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    margin-top: 24px;
  }
  .form-actions button {
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
    font-family: inherit;
  }
  .form-actions button[type="button"] { background: var(--color-bg); color: var(--color-muted); }
  .form-actions button[type="button"]:hover { background: var(--color-border); }
  .form-actions button[type="submit"] { background: var(--color-primary-mid); color: white; }
  .form-actions button[type="submit"]:hover { background: var(--color-primary); }
  .form-actions button:disabled { opacity: 0.6; cursor: not-allowed; }
  .tx-error { color: var(--color-error); font-size: 0.85rem; margin-top: -12px; margin-bottom: 8px; }
  .tx-error.hidden { display: none; }

  .convention-signed {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    background: var(--color-success-bg);
    color: var(--color-success-text);
    border: 1px solid var(--color-success-border);
    border-radius: 50%;
    font-size: 0.65rem;
    font-weight: 700;
    margin-left: 6px;
    vertical-align: middle;
    flex-shrink: 0;
  }

  th.sortable { cursor: pointer; user-select: none; }
  th.sortable:hover { background: var(--color-primary-hover); }
  th.sort-asc .sort-icon::after { content: ' ↑'; }
  th.sort-desc .sort-icon::after { content: ' ↓'; }
  .sort-icon { font-size: 0.7rem; color: var(--color-subtle); }
  th.sort-asc .sort-icon, th.sort-desc .sort-icon { color: var(--color-primary-mid); }

  @media (max-width: 768px) {
    .user-email { display: none; }
    #search { width: 100%; }
  }
</style>

<script>
  // ── Navigation vers le détail membre ──────────────────────────────────────
  document.querySelectorAll<HTMLTableRowElement>('tr.clickable').forEach(row => {
    row.addEventListener('click', () => {
      const id = row.dataset.id;
      if (id) window.location.href = `/admin/membres/${id}`;
    });
  });

  // ── Modal nouveau membre ───────────────────────────────────────────────────
  const membreOverlay = document.getElementById('membre-overlay')!;
  const membreForm = document.getElementById('membre-form') as HTMLFormElement;
  const membreError = document.getElementById('membre-error')!;
  const membreSubmit = document.getElementById('membre-submit') as HTMLButtonElement;

  function openMembreModal() { membreForm.reset(); membreError.classList.add('hidden'); membreOverlay.classList.remove('hidden'); }
  function closeMembreModal() { membreOverlay.classList.add('hidden'); }

  document.getElementById('btn-create-membre')!.addEventListener('click', openMembreModal);
  document.getElementById('membre-close')!.addEventListener('click', closeMembreModal);
  document.getElementById('membre-cancel')!.addEventListener('click', closeMembreModal);
  membreOverlay.addEventListener('click', e => { if (e.target === membreOverlay) closeMembreModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeMembreModal(); });

  membreForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    membreSubmit.disabled = true;
    membreSubmit.textContent = 'Enregistrement…';
    membreError.classList.add('hidden');

    const email = (document.getElementById('m-email') as HTMLInputElement).value.trim();
    const nom = (document.getElementById('m-nom') as HTMLInputElement).value.trim();
    const prenom = (document.getElementById('m-prenom') as HTMLInputElement).value.trim();
    const structure = (document.getElementById('m-structure') as HTMLInputElement).value.trim();
    const role = (document.getElementById('m-role') as HTMLSelectElement).value;

    try {
      const res = await fetch('/api/admin/membre', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, nom: nom || null, prenom: prenom || null, structure: structure || null, role }),
      });
      if (!res.ok) throw new Error(await res.text() || 'Erreur serveur');
      closeMembreModal();
      window.location.reload();
    } catch (err: any) {
      membreError.textContent = err.message;
      membreError.classList.remove('hidden');
    } finally {
      membreSubmit.disabled = false;
      membreSubmit.textContent = 'Créer';
    }
  });

  // ── Envoi conventions en masse ────────────────────────────────────────────
  const bulkOverlay  = document.getElementById('bulk-convention-overlay');
  const bulkError    = document.getElementById('bulk-error')!;
  const bulkSubmit   = document.getElementById('bulk-convention-submit') as HTMLButtonElement | null;
  const btnSendBulk  = document.getElementById('btn-send-conventions');

  if (btnSendBulk && bulkOverlay) {
    btnSendBulk.addEventListener('click', () => {
      bulkError.classList.add('hidden');
      bulkOverlay.classList.remove('hidden');
    });
    document.getElementById('bulk-convention-close')!.addEventListener('click', () => bulkOverlay.classList.add('hidden'));
    document.getElementById('bulk-convention-cancel')!.addEventListener('click', () => bulkOverlay.classList.add('hidden'));
    bulkOverlay.addEventListener('click', e => { if (e.target === bulkOverlay) bulkOverlay.classList.add('hidden'); });

    bulkSubmit?.addEventListener('click', async () => {
      bulkSubmit.disabled = true;
      bulkSubmit.textContent = 'Envoi en cours…';
      bulkError.classList.add('hidden');

      const res = await fetch('/api/admin/send-conventions-bulk', { method: 'POST' });

      if (!res.ok) {
        bulkError.textContent = await res.text();
        bulkError.classList.remove('hidden');
        bulkSubmit.disabled = false;
        bulkSubmit.textContent = 'Envoyer';
        return;
      }

      const { sent } = await res.json();
      bulkSubmit.textContent = `${sent} email${sent > 1 ? 's' : ''} envoyé${sent > 1 ? 's' : ''} ✓`;
      setTimeout(() => {
        bulkOverlay.classList.add('hidden');
        bulkSubmit.disabled = false;
        bulkSubmit.textContent = 'Envoyer';
      }, 2500);
    });
  }

  // ── Filtrage ──────────────────────────────────────────────────────────────
  const search = document.getElementById('search') as HTMLInputElement;
  const tbody = document.querySelector<HTMLTableSectionElement>('#membres-table tbody')!;
  const getRows = () => Array.from(tbody.querySelectorAll<HTMLTableRowElement>('tr'));

  search.addEventListener('input', () => {
    const q = search.value.toLowerCase().trim();
    getRows().forEach(row => {
      const nom = row.cells[0]?.textContent?.toLowerCase() ?? '';
      const email = row.cells[1]?.textContent?.toLowerCase() ?? '';
      row.classList.toggle('hidden', q !== '' && !nom.includes(q) && !email.includes(q));
    });
  });

  // ── Tri ───────────────────────────────────────────────────────────────────
  let sortCol = -1;
  let sortAsc = true;

  document.querySelectorAll<HTMLTableCellElement>('th.sortable').forEach(th => {
    th.addEventListener('click', () => {
      const col = parseInt(th.dataset.col ?? '0');
      if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = true; }
      document.querySelectorAll('th').forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
      th.classList.add(sortAsc ? 'sort-asc' : 'sort-desc');

      const rows = getRows();
      rows.sort((a, b) => {
        const aText = a.cells[col]?.textContent?.trim() ?? '';
        const bText = b.cells[col]?.textContent?.trim() ?? '';
        const aNum = parseFloat(aText.replace(/[^0-9,.-]/g, '').replace(',', '.'));
        const bNum = parseFloat(bText.replace(/[^0-9,.-]/g, '').replace(',', '.'));
        const isNum = !isNaN(aNum) && !isNaN(bNum);
        const dateRe = /^\d{2}\/\d{2}\/\d{4}$/;
        const isDate = dateRe.test(aText) && dateRe.test(bText);
        let cmp = 0;
        if (isDate) {
          const [ad, am, ay] = aText.split('/');
          const [bd, bm, by] = bText.split('/');
          cmp = new Date(`${ay}-${am}-${ad}`).getTime() - new Date(`${by}-${bm}-${bd}`).getTime();
        } else if (isNum) {
          cmp = aNum - bNum;
        } else {
          cmp = aText.localeCompare(bText, 'fr');
        }
        return sortAsc ? cmp : -cmp;
      });
      rows.forEach(row => tbody.appendChild(row));
    });
  });
</script>
