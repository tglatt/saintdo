---
import { createAdminClient } from '../../../lib/supabase';
import AdminNav from '../../../components/AdminNav.astro';
import '../../../styles/theme.css';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin');

const supabase = createAdminClient();

const { data: membre } = await supabase
  .from('membres')
  .select('id, email, nom, prenom, address, zip_code, city, country, role, structure, created_at, convention_email_sent_at')
  .eq('id', id)
  .single();
if (!membre) return Astro.redirect('/admin');

const { data: transactions } = await supabase
  .from('transactions')
  .select('id, type, montant, date, paiement, detail, helloasso_order_id, convention_id')
  .eq('membre_id', id)
  .order('date', { ascending: false });

const { data: convention } = await supabase
  .from('conventions')
  .select('id, signed_at')
  .eq('membre_id', id)
  .order('signed_at', { ascending: false })
  .limit(1)
  .maybeSingle();

function euros(n: number) {
  return n.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
}
function fmtDate(iso: string | null) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

const nomComplet = [membre.prenom, membre.nom].filter(Boolean).join(' ') || membre.email;
const adresseParts = [
  membre.address,
  membre.zip_code && membre.city ? `${membre.zip_code} ${membre.city}` : (membre.zip_code || membre.city),
  membre.country,
].filter(Boolean);

const total = transactions?.reduce((s, t) => s + t.montant, 0) ?? 0;
const hasApport = transactions?.some(t => t.type === 'apport_associatif') ?? false;

const typeLabel: Record<string, string> = {
  adhesion: 'Adhésion',
  don: 'Don',
  don_defiscalise: 'Don défiscalisé',
  apport_associatif: 'Apport associatif',
};
const paiementLabel: Record<string, string> = {
  helloasso: 'HelloAsso',
  cheque: 'Chèque',
  virement: 'Virement',
};
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{nomComplet} — Admin Saint Domingue</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <AdminNav activePage="membres" userEmail={user.email} />

  <main>
    <div class="container">

      <a href="/admin" class="back-link">← Retour aux membres</a>

      <!-- HEADER MEMBRE -->
      <div class="member-header">
        <div class="member-header-left">
          <h1>{nomComplet}</h1>
          <div class="member-meta">
            <span class="member-email">{membre.email}</span>
            {membre.structure && <span class="sep">·</span>}
            {membre.structure && <span class="member-structure">{membre.structure}</span>}
            <span class="sep">·</span>
            <span class={`badge badge-${membre.role}`}>{membre.role === 'admin' ? 'Admin' : 'Membre'}</span>
          </div>
          {adresseParts.length > 0 && (
            <div class="member-address">{adresseParts.join(', ')}</div>
          )}
          {(membre.date_naissance || membre.ville_naissance || membre.departement_naissance) && (
            <div class="member-address">
              Né(e)
              {membre.date_naissance && ` le ${fmtDate(membre.date_naissance)}`}
              {membre.ville_naissance && ` à ${membre.ville_naissance}`}
              {membre.departement_naissance && ` (${membre.departement_naissance})`}
            </div>
          )}
        </div>
        <div class="member-header-actions">
          <button id="btn-edit" class="btn-secondary">Modifier</button>
          {hasApport && !convention && (
            <button id="btn-send-convention" class="btn-secondary">Envoyer la convention</button>
          )}
          {convention && (
            <a href={`/api/admin/convention?membre_id=${membre.id}`} target="_blank" class="btn-secondary">
              Télécharger la convention
            </a>
          )}
          {convention && (
            <button id="btn-delete-convention" class="btn-danger">Supprimer la convention</button>
          )}
          <button id="btn-add-tx" class="btn-primary">+ Transaction</button>
        </div>
      </div>

      <!-- CONVENTION STATUS -->
      {convention ? (
        <div class="convention-badge convention-badge--signed">
          ✓ Convention signée le {fmtDate(convention.signed_at)}
        </div>
      ) : hasApport ? (
        <div class="convention-badge convention-badge--pending">
          Convention en attente de signature
          {membre.convention_email_sent_at && (
            <span class="convention-email-sent"> · Email envoyé le {fmtDate(membre.convention_email_sent_at)}</span>
          )}
        </div>
      ) : null}

      <!-- TRANSACTIONS -->
      <section class="section">
        <div class="section-header">
          <h2>Transactions</h2>
        </div>

        {transactions?.length ? (
          <div class="table-wrapper">
            <table class="tx-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Type</th>
                  <th>Paiement</th>
                  <th class="right">Montant</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                {transactions.map(t => (
                  <>
                    <tr data-tx-id={t.id}>
                      <td class="tx-date">{fmtDate(t.date)}</td>
                      <td><span class={`badge badge-${t.type}`}>{typeLabel[t.type] ?? t.type}</span></td>
                      <td class="tx-paiement">{t.paiement ? (paiementLabel[t.paiement] ?? t.paiement) : <span class="muted">—</span>}</td>
                      <td class="right tx-montant">{euros(t.montant)}</td>
                      <td class="tx-actions">
                        {t.convention_id ? (
                          <span class="tx-lock" title="Verrouillée par une convention">🔒</span>
                        ) : (
                          <>
                            <button class="btn-edit-tx" data-tx-id={t.id}>✏</button>
                            <button class="btn-move-tx" data-tx-id={t.id} title="Déplacer vers un autre membre">⇄</button>
                          </>
                        )}
                      </td>
                    </tr>
                    {t.detail && (
                      <tr class="tx-detail-row">
                        <td colspan="5" class="tx-detail">{t.detail}</td>
                      </tr>
                    )}
                  </>
                ))}
              </tbody>
            </table>
            <div class="tx-total">
              <span>Total</span>
              <span>{euros(total)}</span>
            </div>
          </div>
        ) : (
          <p class="empty">Aucune transaction.</p>
        )}
      </section>

    </div>
  </main>

  <!-- MODAL MODIFIER MEMBRE -->
  <div id="edit-overlay" class="modal-overlay hidden">
    <div class="modal">
      <div class="modal-header">
        <h2>Modifier le membre</h2>
        <button id="edit-close" class="modal-close" data-modal-close>✕</button>
      </div>
      <div class="modal-body">
        <div id="edit-error" class="form-error hidden"></div>
        <div class="form-row">
          <div class="form-group">
            <label>Prénom</label>
            <input id="em-prenom" type="text" value={membre.prenom ?? ''} autocomplete="off" />
          </div>
          <div class="form-group">
            <label>Nom</label>
            <input id="em-nom" type="text" value={membre.nom ?? ''} autocomplete="off" />
          </div>
        </div>
        <div class="form-group">
          <label>Email <span class="required">*</span></label>
          <input id="em-email" type="email" value={membre.email} autocomplete="off" />
        </div>
        <div class="form-actions">
          <button type="button" id="edit-cancel" data-modal-close>Annuler</button>
          <button type="button" id="edit-submit">Enregistrer</button>
        </div>
      </div>
    </div>
  </div>

  <!-- MODAL DÉPLACER TRANSACTION -->
  <div id="move-overlay" class="modal-overlay hidden">
    <div class="modal">
      <div class="modal-header">
        <h2>Déplacer la transaction</h2>
        <button id="move-close" class="modal-close" data-modal-close>✕</button>
      </div>
      <div class="modal-body">
        <p id="move-tx-info" class="move-tx-info"></p>
        <div class="form-group">
          <label>Membre destinataire</label>
          <input type="text" id="move-search" placeholder="Rechercher par nom ou email…" autocomplete="off" />
        </div>
        <div id="move-results" class="move-results"></div>
        <p id="move-error" class="form-error hidden"></p>
        <div class="form-actions">
          <button type="button" id="move-cancel" data-modal-close>Annuler</button>
          <button type="button" id="move-submit" disabled>Déplacer</button>
        </div>
      </div>
    </div>
  </div>

  <!-- MODAL SUPPRIMER CONVENTION -->
  {convention && (
    <div id="delete-convention-overlay" class="modal-overlay hidden">
      <div class="modal modal--sm">
        <div class="modal-header">
          <h2>Supprimer la convention</h2>
          <button id="delete-convention-close" class="modal-close" data-modal-close>✕</button>
        </div>
        <div class="modal-body">
          <p class="delete-warning">Cette action est irréversible. La convention signée le <strong>{fmtDate(convention.signed_at)}</strong> sera supprimée et les transactions associées seront dissociées.</p>
          <p id="delete-convention-error" class="form-error hidden"></p>
          <div class="form-actions">
            <button type="button" id="delete-convention-cancel" data-modal-close>Annuler</button>
            <button type="button" id="delete-convention-confirm" class="btn-action-danger">Supprimer</button>
          </div>
        </div>
      </div>
    </div>
  )}

  <!-- MODAL TRANSACTION -->
  <div id="tx-overlay" class="modal-overlay hidden">
    <div class="modal">
      <div class="modal-header">
        <h2 id="tx-title">Nouvelle transaction</h2>
        <button id="tx-close" class="modal-close" data-modal-close>✕</button>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label>Type</label>
          <select id="tx-type" required>
            <option value="">— Sélectionner —</option>
            <option value="adhesion">Adhésion</option>
            <option value="don">Don</option>
            <option value="don_defiscalise">Don défiscalisé</option>
            <option value="apport_associatif">Apport associatif</option>
          </select>
        </div>
        <div class="form-group">
          <label>Montant (€)</label>
          <input type="number" id="tx-montant" min="1" step="1" required placeholder="100" />
        </div>
        <div class="form-group">
          <label>Date</label>
          <input type="date" id="tx-date" />
        </div>
        <div class="form-group">
          <label>Moyen de paiement</label>
          <select id="tx-paiement">
            <option value="">— Sélectionner —</option>
            <option value="helloasso">HelloAsso</option>
            <option value="cheque">Chèque</option>
            <option value="virement">Virement</option>
          </select>
        </div>
        <div class="form-group">
          <label>Détail</label>
          <textarea id="tx-detail" rows="3" placeholder="Informations complémentaires…"></textarea>
        </div>
        <p id="tx-error" class="form-error hidden"></p>
        <div class="form-actions">
          <button type="button" id="tx-cancel" data-modal-close>Annuler</button>
          <button type="button" id="tx-submit">Créer</button>
        </div>
      </div>
    </div>
  </div>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--color-bg);
    color: var(--color-text);
    min-height: 100vh;
  }

  main { padding: 32px 24px 80px; }
  .container { max-width: 900px; margin: 0 auto; }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 24px;
    transition: color 0.2s;
  }
  .back-link:hover { color: var(--color-primary); }

  /* Header */
  .member-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    background: white;
    border-radius: 12px;
    padding: 28px 32px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .member-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    color: var(--color-primary);
    margin-bottom: 8px;
  }
  .member-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .member-email { font-size: 0.9rem; color: var(--color-muted); }
  .member-structure { font-size: 0.9rem; color: var(--color-muted); }
  .sep { color: var(--color-subtle); }
  .member-address { font-size: 0.85rem; color: var(--color-subtle); margin-top: 4px; }
  .member-header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .badge { display: inline-block; padding: 2px 10px; border-radius: 99px; font-size: 0.75rem; font-weight: 600; }
  .badge-membre { background: var(--badge-membre-bg); color: var(--badge-membre-text); }
  .badge-admin  { background: var(--badge-admin-bg);  color: var(--badge-admin-text); }
  .badge-adhesion        { background: var(--badge-adhesion-bg);        color: var(--badge-adhesion-text); }
  .badge-don             { background: var(--badge-don-bg);             color: var(--badge-don-text); }
  .badge-don_defiscalise { background: var(--badge-don_defiscalise-bg); color: var(--badge-don_defiscalise-text); }
  .badge-apport_associatif { background: var(--badge-apport_associatif-bg); color: var(--badge-apport_associatif-text); }

  /* Convention status */
  .convention-badge {
    padding: 10px 16px;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 500;
    margin-bottom: 24px;
  }
  .convention-badge--signed {
    background: var(--color-success-bg);
    color: var(--color-success-text);
    border: 1px solid var(--color-success-border);
  }
  .convention-badge--pending {
    background: var(--color-surface);
    color: var(--color-muted);
    border: 1px solid var(--color-border);
  }

  /* Section */
  .section { margin-bottom: 32px; }
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .section-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: var(--color-primary);
  }

  .table-wrapper { overflow-x: auto; }
  .tx-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    min-width: 500px;
  }
  .tx-table th {
    text-align: left;
    padding: 10px 16px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .tx-table td {
    padding: 10px 16px;
    font-size: 0.88rem;
    border-bottom: 1px solid var(--color-border-light);
  }
  .tx-table tr:last-child td { border-bottom: none; }
  .right { text-align: right; }
  .muted { color: var(--color-muted); }
  .tx-date { color: var(--color-muted); white-space: nowrap; }
  .tx-paiement { font-size: 0.82rem; color: var(--color-muted); }
  .tx-montant { font-weight: 600; white-space: nowrap; }
  .tx-actions { text-align: right; white-space: nowrap; }
  .tx-lock {
    font-size: 0.85rem;
    opacity: 0.4;
    padding: 2px 4px;
  }
  .tx-table tr:hover .tx-lock { opacity: 0.7; }
  .btn-edit-tx,
  .btn-move-tx {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--color-subtle);
    padding: 2px 4px;
    border-radius: 4px;
    transition: all 0.15s;
    opacity: 0;
  }
  .tx-table tr:hover .btn-edit-tx,
  .tx-table tr:hover .btn-move-tx { opacity: 1; }
  .btn-edit-tx:hover,
  .btn-move-tx:hover { color: var(--color-primary-mid); background: var(--color-success-bg); }

  .move-tx-info {
    font-size: 0.88rem;
    color: var(--color-muted);
    background: var(--color-bg);
    border-radius: 8px;
    padding: 10px 14px;
    margin-bottom: 18px;
    font-style: italic;
  }
  .move-results {
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-height: 220px;
    overflow-y: auto;
    margin-bottom: 12px;
  }
  .move-result-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: 100%;
    text-align: left;
    padding: 8px 12px;
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    background: white;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.88rem;
    transition: all 0.15s;
  }
  .move-result-item:hover { border-color: var(--color-primary-mid); background: var(--color-bg); }
  .move-result-item.selected { border-color: var(--color-primary-mid); background: var(--color-success-bg); }
  .move-result-email { font-size: 0.78rem; color: var(--color-muted); flex-shrink: 0; }
  .move-no-results { font-size: 0.85rem; color: var(--color-subtle); padding: 8px 0; }
  .tx-detail-row td { padding-top: 0 !important; padding-bottom: 10px !important; }
  .tx-detail {
    font-size: 0.8rem;
    color: var(--color-muted);
    font-style: italic;
    padding-left: 16px !important;
    border-left: 2px solid var(--color-border);
  }
  .tx-total {
    display: flex;
    justify-content: space-between;
    padding: 14px 16px 0;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-primary);
    border-top: 2px solid var(--color-border);
    margin-top: 4px;
  }
  .empty { font-size: 0.9rem; color: var(--color-subtle); padding: 16px 0; }

  /* Buttons */
  .btn-primary {
    padding: 8px 16px;
    background: var(--color-primary-mid);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    text-decoration: none;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .btn-primary:hover { background: var(--color-primary); }
  .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
  .btn-secondary {
    padding: 8px 16px;
    background: white;
    color: var(--color-text);
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
    text-decoration: none;
    display: inline-block;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .btn-secondary:hover { background: var(--color-bg); border-color: var(--color-primary-mid); }
  .btn-secondary:disabled { opacity: 0.6; cursor: not-allowed; }
  .btn-danger {
    padding: 8px 16px;
    background: white;
    color: var(--color-error);
    border: 1.5px solid var(--color-error);
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
    transition: all 0.2s;
  }
  .btn-danger:hover { background: #fff0f0; }
  .modal--sm { max-width: 380px; }
  .delete-warning {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: 20px;
  }
  .btn-action-danger { background: var(--color-error) !important; color: white !important; }
  .btn-action-danger:hover { opacity: 0.88; }

  /* Modals */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .modal-overlay.hidden { display: none; }
  .modal {
    background: white;
    border-radius: 16px;
    width: 100%;
    max-width: 480px;
    max-height: 88vh;
    overflow-y: auto;
    box-shadow: 0 8px 48px rgba(0,0,0,0.18);
  }
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 24px 28px 20px;
    border-bottom: 1px solid var(--color-border-light);
    position: sticky;
    top: 0;
    background: white;
  }
  .modal-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: var(--color-primary);
  }
  .modal-close {
    background: none;
    border: none;
    font-size: 1.1rem;
    color: var(--color-subtle);
    cursor: pointer;
    padding: 4px 8px;
  }
  .modal-close:hover { color: var(--color-text); }
  .modal-body { padding: 24px 28px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group { margin-bottom: 18px; }
  .form-group label {
    display: block;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    margin-bottom: 6px;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 10px 14px;
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    background: white;
    color: var(--color-text);
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus { border-color: var(--color-primary-mid); }
  .form-group textarea { resize: vertical; }
  .required { color: var(--color-error); }
  .form-error {
    color: var(--color-error);
    font-size: 0.85rem;
    margin-bottom: 12px;
  }
  .form-error.hidden { display: none; }
  .form-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    margin-top: 8px;
  }
  .form-actions button {
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    font-family: inherit;
    transition: all 0.2s;
  }
  .form-actions button:first-child { background: var(--color-bg); color: var(--color-muted); }
  .form-actions button:first-child:hover { background: var(--color-border); }
  .form-actions button:last-child { background: var(--color-primary-mid); color: white; }
  .form-actions button:last-child:hover { background: var(--color-primary); }
  .form-actions button:disabled { opacity: 0.6; cursor: not-allowed; }

  @media (max-width: 640px) {
    .user-email { display: none; }
    .member-header { flex-direction: column; }
    .member-header-actions { width: 100%; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{ membreId: membre.id }}>
  // ── Helper modal ──────────────────────────────────────────────────────────────
  function setupModal(overlay, { onOpen } = {}) {
    const close = () => overlay.classList.add('hidden');
    const open  = () => { onOpen?.(); overlay.classList.remove('hidden'); };
    overlay.addEventListener('click', e => { if (e.target === overlay) close(); });
    overlay.querySelectorAll('[data-modal-close]').forEach(el => el.addEventListener('click', close));
    return { open, close };
  }

  // ── Edit member ──────────────────────────────────────────────────────────────
  const editError  = document.getElementById('edit-error');
  const editModal  = setupModal(document.getElementById('edit-overlay'), {
    onOpen: () => editError.classList.add('hidden'),
  });
  document.getElementById('btn-edit').addEventListener('click', editModal.open);

  document.getElementById('edit-submit').addEventListener('click', async () => {
    const btn   = document.getElementById('edit-submit');
    const email = document.getElementById('em-email').value.trim();
    if (!email) { editError.textContent = 'Email requis'; editError.classList.remove('hidden'); return; }

    btn.disabled = true;
    const res = await fetch('/api/admin/membre', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id: membreId,
        prenom: document.getElementById('em-prenom').value,
        nom:    document.getElementById('em-nom').value,
        email,
      }),
    });
    btn.disabled = false;

    if (!res.ok) { editError.textContent = await res.text(); editError.classList.remove('hidden'); return; }
    window.location.reload();
  });

  // ── Transaction modal ─────────────────────────────────────────────────────────
  const txError  = document.getElementById('tx-error');
  const txTitle  = document.getElementById('tx-title');
  const txSubmit = document.getElementById('tx-submit');
  const txModal  = setupModal(document.getElementById('tx-overlay'));
  let currentTxId = null;

  function openTxModal(mode = 'create', tx = null) {
    currentTxId = mode === 'edit' ? tx?.id ?? null : null;
    txTitle.textContent  = mode === 'edit' ? 'Modifier la transaction' : 'Nouvelle transaction';
    txSubmit.textContent = mode === 'edit' ? 'Enregistrer' : 'Créer';
    document.getElementById('tx-type').value     = tx?.type ?? '';
    document.getElementById('tx-montant').value  = tx?.montant?.toString() ?? '';
    document.getElementById('tx-date').value     = tx?.date ? tx.date.split('T')[0] : new Date().toISOString().split('T')[0];
    document.getElementById('tx-paiement').value = tx?.paiement ?? '';
    document.getElementById('tx-detail').value   = tx?.detail ?? '';
    txError.classList.add('hidden');
    txModal.open();
  }

  document.getElementById('btn-add-tx').addEventListener('click', () => openTxModal('create'));

  document.querySelectorAll('.btn-edit-tx').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const txId = btn.dataset.txId;
      const row = document.querySelector(`tr[data-tx-id="${txId}"]`);
      const detailRow = row?.nextElementSibling?.classList.contains('tx-detail-row') ? row.nextElementSibling : null;
      const type = row?.querySelector('.badge')?.className.match(/badge-(\S+)/)?.[1];
      const montant = parseFloat(row?.querySelector('.tx-montant')?.textContent?.replace(/[^0-9,]/g, '').replace(',', '.') ?? '0');
      openTxModal('edit', { id: txId, type, montant, detail: detailRow?.querySelector('.tx-detail')?.textContent ?? '' });
    });
  });

  txSubmit.addEventListener('click', async () => {
    txSubmit.disabled = true;
    const isEdit = currentTxId !== null;
    const payload = isEdit
      ? { id: currentTxId, type: document.getElementById('tx-type').value, montant: Number(document.getElementById('tx-montant').value), date: document.getElementById('tx-date').value || null, paiement: document.getElementById('tx-paiement').value || null, detail: document.getElementById('tx-detail').value.trim() || null }
      : { membre_id: membreId, type: document.getElementById('tx-type').value, montant: Number(document.getElementById('tx-montant').value), date: document.getElementById('tx-date').value || null, paiement: document.getElementById('tx-paiement').value || null, detail: document.getElementById('tx-detail').value.trim() || null };

    const res = await fetch('/api/admin/transaction', {
      method: isEdit ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    txSubmit.disabled = false;

    if (!res.ok) { txError.textContent = await res.text(); txError.classList.remove('hidden'); return; }
    window.location.reload();
  });

  // ── Déplacer transaction ──────────────────────────────────────────────────────
  const moveError   = document.getElementById('move-error');
  const moveSubmit  = document.getElementById('move-submit');
  const moveSearch  = document.getElementById('move-search');
  const moveResults = document.getElementById('move-results');
  const moveTxInfo  = document.getElementById('move-tx-info');
  const moveModal   = setupModal(document.getElementById('move-overlay'));
  let moveTxId = null;
  let moveTargetId = null;

  async function searchMembres(q) {
    const res = await fetch(`/api/admin/membre?q=${encodeURIComponent(q)}`);
    if (!res.ok) return;
    const { membres } = await res.json();
    const filtered = membres.filter(m => m.id !== membreId);
    if (filtered.length === 0) {
      moveResults.innerHTML = '<p class="move-no-results">Aucun membre trouvé.</p>';
      return;
    }
    moveResults.innerHTML = filtered.map(m => {
      const nom = [m.prenom, m.nom].filter(Boolean).join(' ') || m.email;
      return `<button class="move-result-item" data-id="${m.id}">${nom}<span class="move-result-email">${m.email}</span></button>`;
    }).join('');
    moveResults.querySelectorAll('.move-result-item').forEach(btn => {
      btn.addEventListener('click', () => {
        moveResults.querySelectorAll('.move-result-item').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        moveTargetId = btn.dataset.id;
        moveSubmit.disabled = false;
      });
    });
  }

  function openMoveModal(txId, summary) {
    moveTxId = txId;
    moveTargetId = null;
    moveTxInfo.textContent = summary;
    moveSearch.value = '';
    moveResults.innerHTML = '';
    moveError.classList.add('hidden');
    moveSubmit.disabled = true;
    moveModal.open();
    moveSearch.focus();
    searchMembres('');
  }

  let searchTimer = null;
  moveSearch.addEventListener('input', () => {
    clearTimeout(searchTimer);
    moveTargetId = null;
    moveSubmit.disabled = true;
    searchTimer = setTimeout(() => searchMembres(moveSearch.value), 300);
  });

  document.querySelectorAll('.btn-move-tx').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const txId = btn.dataset.txId;
      const row = document.querySelector(`tr[data-tx-id="${txId}"]`);
      openMoveModal(txId, `${row?.querySelector('.badge')?.textContent ?? ''} · ${row?.querySelector('.tx-montant')?.textContent ?? ''} · ${row?.querySelector('.tx-date')?.textContent ?? ''}`);
    });
  });

  moveSubmit.addEventListener('click', async () => {
    if (!moveTxId || !moveTargetId) return;
    moveSubmit.disabled = true;
    moveError.classList.add('hidden');
    const res = await fetch('/api/admin/transaction', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: moveTxId, membre_id: moveTargetId }),
    });
    if (!res.ok) { moveError.textContent = await res.text(); moveError.classList.remove('hidden'); moveSubmit.disabled = false; return; }
    window.location.reload();
  });

  // ── Supprimer convention ──────────────────────────────────────────────────────
  const deleteConventionOverlayEl = document.getElementById('delete-convention-overlay');
  if (deleteConventionOverlayEl) {
    const deleteConventionError = document.getElementById('delete-convention-error');
    const deleteModal = setupModal(deleteConventionOverlayEl, {
      onOpen: () => deleteConventionError.classList.add('hidden'),
    });
    document.getElementById('btn-delete-convention').addEventListener('click', deleteModal.open);

    document.getElementById('delete-convention-confirm').addEventListener('click', async () => {
      const btn = document.getElementById('delete-convention-confirm');
      btn.disabled = true;
      const res = await fetch(`/api/admin/convention?membre_id=${membreId}`, { method: 'DELETE' });
      if (!res.ok) {
        deleteConventionError.textContent = await res.text();
        deleteConventionError.classList.remove('hidden');
        btn.disabled = false;
        return;
      }
      window.location.reload();
    });
  }

  // ── Envoyer convention ────────────────────────────────────────────────────────
  const btnConvention = document.getElementById('btn-send-convention');
  btnConvention?.addEventListener('click', async () => {
    const label = btnConvention.textContent;
    btnConvention.disabled = true;
    btnConvention.textContent = 'Envoi…';

    const res = await fetch('/api/admin/send-convention', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ membre_id: membreId }),
    });

    if (!res.ok) {
      alert(`Erreur : ${await res.text()}`);
      btnConvention.textContent = label;
      btnConvention.disabled = false;
      return;
    }

    btnConvention.textContent = 'Envoyé ✓';
    setTimeout(() => { btnConvention.textContent = label; btnConvention.disabled = false; }, 3000);
  });

  // ── Escape ────────────────────────────────────────────────────────────────────
  document.addEventListener('keydown', e => {
    if (e.key !== 'Escape') return;
    document.querySelectorAll('.modal-overlay:not(.hidden)').forEach(el => el.classList.add('hidden'));
  });
</script>
