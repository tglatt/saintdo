---
import { createAdminClient } from '../../lib/supabase';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const supabase = createAdminClient();

const { data: membre } = await supabase
  .from('membres')
  .select('nom, prenom, role, created_at')
  .eq('email', user.email)
  .single();

const { data: transactions } = await supabase
  .from('transactions')
  .select('type, montant, date, paiement')
  .eq('membre_id', (await supabase.from('membres').select('id').eq('email', user.email).single()).data?.id)
  .order('date', { ascending: false });

const totalAdhesion = transactions?.filter(t => ['adhesion', 'don', 'don_defiscalise'].includes(t.type)).reduce((s, t) => s + t.montant, 0) ?? 0;
const totalApport = transactions?.filter(t => t.type === 'apport_associatif').reduce((s, t) => s + t.montant, 0) ?? 0;

const TYPE_ORDER = ['adhesion', 'don', 'don_defiscalise', 'apport_associatif'];
const typeLabel: Record<string, string> = {
  adhesion: 'Adhésions',
  don: 'Dons',
  don_defiscalise: 'Dons défiscalisés',
  apport_associatif: 'Apports associatifs',
};

const grouped = new Map<string, { date: string | null; montant: number }[]>();
for (const tx of transactions ?? []) {
  if (!grouped.has(tx.type)) grouped.set(tx.type, []);
  grouped.get(tx.type)!.push(tx);
}
const groups = TYPE_ORDER
  .filter(t => grouped.has(t))
  .map(type => ({
    type,
    rows: (grouped.get(type) ?? []).sort((a, b) =>
      new Date(b.date ?? 0).getTime() - new Date(a.date ?? 0).getTime()
    ),
    total: (grouped.get(type) ?? []).reduce((s, t) => s + t.montant, 0),
  }));

function euros(n: number) {
  return n.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
}
function fmtDate(iso: string | null) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Espace membre — Saint Domingue</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <nav>
    <div class="nav-inner">
      <a href="/" class="logo">Saint Domingue</a>
      <div class="nav-right">
        {membre?.role === 'admin' && <a href="/admin" class="btn-admin">Admin</a>}
        <span class="user-email">{user.email}</span>
        <a href="/auth/logout" class="btn-logout">Déconnexion</a>
      </div>
    </div>
  </nav>

  <main>
    <div class="container">

      <header class="page-header">
        <h1>Bonjour{membre?.prenom ? `, ${membre.prenom}` : ''} 👋</h1>
        <p class="sub">Voici un récapitulatif de votre participation au projet Saint Domingue.</p>
      </header>

      <!-- RÉCAP -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">Adhésions & dons</div>
          <div class="stat-value">{euros(totalAdhesion)}</div>
        </div>
        <div class="stat-card stat-card--accent">
          <div class="stat-label">Parts sociales</div>
          <div class="stat-value">{euros(totalApport)}</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Membre depuis</div>
          <div class="stat-value stat-value--sm">{fmtDate(membre?.created_at ?? null)}</div>
        </div>
      </div>

      <!-- TRANSACTIONS -->
      <section class="section">
        <div class="section-header">
          <h2>Historique de vos transactions</h2>
          {groups.length > 0 && (
            <button id="btn-recu" class="btn-download">Télécharger le reçu (PDF)</button>
          )}
        </div>
        {groups.length > 0 ? (
          <table>
            <thead>
              <tr>
                <th>Type</th>
                <th>Date</th>
                <th class="right">Montant</th>
              </tr>
            </thead>
            <tbody>
              {groups.map(g => (
                <tr>
                  <td><span class={`badge badge-${g.type}`}>{typeLabel[g.type] ?? g.type}</span></td>
                  <td class="muted">{fmtDate(g.rows[0]?.date ?? null)}</td>
                  <td class="right">{euros(g.total)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p class="empty">Aucune transaction enregistrée pour le moment.</p>
        )}
      </section>

    </div>
  </main>

  <script type="application/json" id="recu-data" set:html={JSON.stringify({
    nom: [membre?.nom, membre?.prenom].filter(Boolean).join(' ') || user.email,
    email: user.email,
    rows: (transactions ?? []).map(t => ({
      label: typeLabel[t.type] ?? t.type,
      date: t.date ?? null,
      paiement: t.paiement ?? null,
      montant: t.montant,
    })),
    totalAdhesion,
    totalApport,
  })}></script>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script>
    document.getElementById('btn-recu')?.addEventListener('click', async () => {
      const data = JSON.parse(document.getElementById('recu-data').textContent);
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF({ unit: 'mm', format: 'a4' });

      const green = [27, 67, 50];
      const lightBg = [247, 243, 238];
      const grey = [92, 92, 107];
      const pageW = doc.internal.pageSize.getWidth();
      const marginL = 16;
      const marginR = pageW - 16;

      function eur(n) {
        return Math.round(n).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ' ') + ' EUR';
      }

      // En-tête
      doc.setFillColor(...green);
      doc.rect(0, 0, pageW, 36, 'F');
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(14);
      doc.setTextColor(255, 255, 255);
      doc.text('Le Saint-Domingue', marginL, 11);
      doc.setFontSize(8);
      doc.setFont('helvetica', 'normal');
      doc.text('85 impasse de la Gélibaudière — 26150 Die', marginL, 18);
      doc.text('SIRET : 10073905100017', marginL, 24);
      const today = new Date().toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
      doc.text(`Édité le ${today}`, marginR, 24, { align: 'right' });

      // Titre
      doc.setFontSize(18);
      doc.setFont('helvetica', 'bold');
      doc.setTextColor(...green);
      doc.text('Reçu', marginL, 52);

      // Infos membre
      doc.setFontSize(9);
      doc.setFontSize(10);
      doc.setTextColor(28, 28, 30);
      doc.setFont('helvetica', 'bold');
      doc.text(data.nom, marginL, 68);
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(9);
      doc.setTextColor(...grey);
      doc.text(data.email, marginL, 74);

      // Table header
      let y = 84;
      const rowH = 9;
      const colType = marginL;
      const colDate = 80;
      const colPaiement = 120;
      const colMontant = marginR;

      const paiementLabel = { helloasso: 'HelloAsso', virement: 'Virement', cheque: 'Chèque' };

      doc.setFillColor(...green);
      doc.rect(marginL, y, marginR - marginL, rowH, 'F');
      doc.setFont('helvetica', 'bold');
      doc.setFontSize(9);
      doc.setTextColor(255, 255, 255);
      doc.text('Type', colType + 3, y + 6);
      doc.text('Date', colDate, y + 6);
      doc.text('Paiement', colPaiement, y + 6);
      doc.text('Montant', colMontant, y + 6, { align: 'right' });
      y += rowH;

      // Grouper par date + type + paiement
      const grouped = new Map();
      for (const r of data.rows) {
        const key = `${r.date}||${r.label}||${r.paiement}`;
        if (grouped.has(key)) {
          grouped.get(key).montant += r.montant;
        } else {
          grouped.set(key, { ...r });
        }
      }
      const groupedRows = [...grouped.values()].sort((a, b) => {
        if (!a.date && !b.date) return 0;
        if (!a.date) return 1;
        if (!b.date) return -1;
        return new Date(b.date) - new Date(a.date);
      });

      // Rows
      groupedRows.forEach((r, i) => {
        if (i % 2 === 0) {
          doc.setFillColor(...lightBg);
          doc.rect(marginL, y, marginR - marginL, rowH, 'F');
        }
        const date = r.date
          ? new Date(r.date).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' })
          : '—';
        doc.setFont('helvetica', 'normal');
        doc.setFontSize(9);
        doc.setTextColor(28, 28, 30);
        doc.text(r.label, colType + 3, y + 6);
        doc.setTextColor(...grey);
        doc.text(date, colDate, y + 6);
        doc.text(paiementLabel[r.paiement] ?? '—', colPaiement, y + 6);
        doc.setTextColor(28, 28, 30);
        doc.setFont('helvetica', 'bold');
        doc.text(eur(r.montant), colMontant, y + 6, { align: 'right' });
        y += rowH;
      });

      // Signature
      y += 20;
      doc.setFont('helvetica', 'normal');
      doc.setFontSize(9);
      doc.setTextColor(...grey);
      doc.text('Le Président de l\'association', marginR - 50, y, { align: 'left' });
      y += 5;

      // Tentative de chargement de l'image signature
      const sigX = marginR - 50;
      const sigW = 50;
      const sigH = 20;
      try {
        const res = await fetch('/signature.png');
        if (res.ok) {
          const blob = await res.blob();
          const reader = new FileReader();
          await new Promise(resolve => {
            reader.onload = () => {
              doc.addImage(reader.result, 'PNG', sigX, y, sigW, sigH);
              resolve();
            };
            reader.readAsDataURL(blob);
          });
          y += sigH + 4;
        } else {
          doc.setDrawColor(200, 200, 200);
          doc.setLineWidth(0.3);
          doc.rect(sigX, y, sigW, sigH);
          doc.setFontSize(7);
          doc.setTextColor(180, 180, 180);
          doc.text('[ signature ]', sigX + sigW / 2, y + sigH / 2 + 2, { align: 'center' });
          y += sigH + 4;
        }
      } catch {
        doc.setDrawColor(200, 200, 200);
        doc.setLineWidth(0.3);
        doc.rect(sigX, y, sigW, sigH);
        y += sigH + 4;
      }

      doc.setFont('helvetica', 'bold');
      doc.setFontSize(9);
      doc.setTextColor(28, 28, 30);
      doc.text('Thomas Glatt', marginR - 50, y, { align: 'left' });

      doc.save('recu-saint-domingue.pdf');
    });
  </script>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    background: #F7F3EE;
    color: #1C1C1E;
    min-height: 100vh;
  }

  nav {
    background: white;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .nav-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #1B4332;
    text-decoration: none;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .user-email {
    font-size: 0.85rem;
    color: #5C5C6B;
  }
  .btn-logout {
    font-size: 0.85rem;
    color: #5C5C6B;
    text-decoration: none;
    padding: 6px 12px;
    border: 1px solid #E5E5EA;
    border-radius: 6px;
    transition: all 0.2s;
  }
  .btn-logout:hover { background: #F7F3EE; color: #1C1C1E; }
  .btn-admin {
    font-size: 0.85rem;
    font-weight: 600;
    color: white;
    background: #E76F51;
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 6px;
    transition: background 0.2s;
  }
  .btn-admin:hover { background: #C75B3A; }

  main { padding: 48px 24px; }
  .container { max-width: 1000px; margin: 0 auto; }

  .page-header { margin-bottom: 40px; }
  h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: #1B4332;
    margin-bottom: 8px;
  }
  .sub { color: #5C5C6B; font-size: 1rem; }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 48px;
  }
  .stat-card {
    background: white;
    border-radius: 12px;
    padding: 28px 24px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
  }
  .stat-card--accent { border-top: 3px solid #2D6A4F; }
  .stat-label { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: #5C5C6B; margin-bottom: 10px; }
  .stat-value { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: #1B4332; }
  .stat-value--sm { font-size: 1.1rem; font-weight: 600; font-family: 'Inter', sans-serif; }

  .section h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: #1B4332;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
  }
  th {
    text-align: left;
    padding: 14px 20px;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #5C5C6B;
    background: #F7F3EE;
    border-bottom: 1px solid #E5E5EA;
  }
  td {
    padding: 14px 20px;
    font-size: 0.92rem;
    border-bottom: 1px solid #F0EDE8;
    color: #1C1C1E;
  }
  tr:last-child td { border-bottom: none; }
  .right { text-align: right; }
  .muted { color: #5C5C6B; }

  .groups { display: flex; flex-direction: column; gap: 24px; }
  .group-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .group-total {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: #1B4332;
    font-weight: 700;
  }

  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 99px;
    font-size: 0.78rem;
    font-weight: 600;
  }
  .badge-adhesion { background: #DBEAFE; color: #1D4ED8; }
  .badge-don { background: #D1FAE5; color: #065F46; }
  .badge-don_defiscalise { background: #EDE9FE; color: #5B21B6; }
  .badge-apport_associatif { background: #FEF3C7; color: #92400E; }

  .empty { color: #5C5C6B; font-size: 0.9rem; padding: 24px 0; }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .section-header h2 { margin-bottom: 0; }
  .btn-download {
    padding: 8px 16px;
    background: white;
    color: #2D6A4F;
    border: 1.5px solid #2D6A4F;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .btn-download:hover { background: #F0FDF4; }

  @media (max-width: 640px) {
    .stats-grid { grid-template-columns: 1fr; }
    .user-email { display: none; }
  }
</style>
